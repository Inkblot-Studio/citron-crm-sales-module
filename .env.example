# ---- Citron Sales module (Vite) --------------------------------------------
# Vite only reads variables prefixed with VITE_. (Next.js `NEXT_PUBLIC_*` must be
# copied here; same values, different names.)
# Use either legacy anon (JWT) or the new publishable key — not both required.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
#
# After deploy, the client-facing form (no Citron login) is at: https://<your-host>/intake
# Share that link; submissions appear in Sales → Intake. Same env as this file.

# ---- Supabase Edge Function secrets (server-side only) ---------------------
# Set via `supabase secrets set KEY=VALUE` from the project root, or in the
# Supabase dashboard under Edge Functions → intake-webhook → Secrets.
# These are NEVER read by the Vite app.
#
# TALLY_SIGNING_SECRET=whsec_....       # strongly recommended
# OPENAI_API_KEY=sk-....                # optional — AI summary is skipped if absent
# OPENAI_MODEL=gpt-4o-mini              # optional — defaults to gpt-4o-mini
